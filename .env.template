# FOCOSA Hub - Environment Configuration
# Copy this to .env and update with your values

# ==========================================
# SECURITY
# ==========================================
# Change this to a strong random string in production
SECRET_KEY=focosa-super-secret-key-change-in-prod

# ==========================================
# DATABASE
# ==========================================
# SQLite database path
DB_PATH=focosa.db

# ==========================================
# SERVER CONFIGURATION
# ==========================================
# User/Student API Port
USER_PORT=8000

# Admin API Port
ADMIN_PORT=8001

# ==========================================
# CORS & SECURITY
# ==========================================
# Allowed origins for CORS (comma-separated)
# For local: http://localhost:3000,http://localhost:8000
# For production: update with your domain
ALLOWED_ORIGINS=*

# ==========================================
# TOKEN SETTINGS
# ==========================================
# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Algorithm for JWT tokens
ALGORITHM=HS256

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# ENVIRONMENT
# ==========================================
# development, staging, or production
ENVIRONMENT=development
